# Configuration des APIs sociales pour le partage avec amis

# Facebook
VITE_FACEBOOK_APP_ID=your_facebook_app_id_here

# Twitter
VITE_TWITTER_CLIENT_ID=your_twitter_client_id_here

# LinkedIn
VITE_LINKEDIN_CLIENT_ID=your_linkedin_client_id_here

# Instructions:
# 1. Copiez ce fichier vers .env
# 2. Remplacez les valeurs par vos vraies clés API
# 3. Les variables commençant par VITE_ sont accessibles dans le frontend